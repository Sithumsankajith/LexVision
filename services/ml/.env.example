# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Database ---
# Use psycopg2 for synchronous FastAPI routes (recommended)
DATABASE_URL=postgresql+psycopg2://<user>:<password>@localhost:5432/<database>

# Async variant (for future async migration)
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@localhost:5432/<database>

# SQLite fallback for quick local testing (no Postgres required)
# DATABASE_URL=sqlite:///./db.sqlite3

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
SECRET_KEY=changeme-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Database ---
# Use psycopg2 for synchronous FastAPI routes (recommended)
DATABASE_URL=postgresql+psycopg2://<user>:<password>@localhost:5432/<database>

# Async variant (for future async migration)
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@localhost:5432/<database>

# SQLite fallback for quick local testing (no Postgres required)
# DATABASE_URL=sqlite:///./db.sqlite3

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
SECRET_KEY=changeme-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Firebase Admin (Citizen phone OTP verification) ---
FIREBASE_PROJECT_ID=lexvision-f40aa
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@lexvision-f40aa.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-your-private-key\n-----END PRIVATE KEY-----\n"

# --- SMS Provider Selection ---
# Supported values: noop, twilio, mobitel_msms, dialog_esms, hutch
SMS_PROVIDER=noop
SMS_SENDER_ID=LexVision
SMS_DEFAULT_COUNTRY_CODE=+94
SMS_REQUEST_TIMEOUT_SECONDS=10

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Mobitel mSMS ---
MOBITEL_MSMS_BASE_URL=
MOBITEL_MSMS_API_KEY=
MOBITEL_MSMS_USERNAME=
MOBITEL_MSMS_PASSWORD=

# --- Dialog e-SMS ---
DIALOG_ESMS_BASE_URL=
DIALOG_ESMS_API_KEY=
DIALOG_ESMS_USERNAME=
DIALOG_ESMS_PASSWORD=

# --- HUTCH SMS ---
HUTCH_SMS_BASE_URL=
HUTCH_SMS_API_KEY=
HUTCH_SMS_USERNAME=
HUTCH_SMS_PASSWORD=
